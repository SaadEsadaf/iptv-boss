# AI
ANTHROPIC_API_KEY=your_key_here
AI_KEY_OPENROUTER=your_openrouter_key_here

# Payments
SELLUP_API_KEY=your_sellup_api_key_here
SELLUP_STORE_ID=your_sellup_store_id_here
SELLUP_WEBHOOK_SECRET=your_sellup_webhook_secret_here

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM_NAME=IPTV Boss
SMTP_FROM_EMAIL=your@gmail.com

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
JWT_SECRET=change_this_to_random_string

# Business
SITE_NAME=IPTV Boss
SITE_URL=http://localhost:3000
SUPPORT_EMAIL=your@gmail.com

# VPS Deploy — Default server
VPS_USER=root
VPS_HOST=your.server.ip
VPS_PATH=/var/www/iptv-boss

# VPS Deploy — Region-specific servers (for multi-region deployment)
# bash deploy.sh us  /  bash deploy.sh eu  /  bash deploy.sh asia
# REGION_US_USER=root
# REGION_US_HOST=us.example.com
# REGION_US_PATH=/var/www/iptv-boss
# REGION_EU_USER=root
# REGION_EU_HOST=eu.example.com
# REGION_EU_PATH=/var/www/iptv-boss
# REGION_ASIA_USER=root
# REGION_ASIA_HOST=asia.example.com
# REGION_ASIA_PATH=/var/www/iptv-boss

# Namecheap API (set via Admin → Settings → Namecheap API)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# Server
PORT=3001
